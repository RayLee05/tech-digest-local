{
  "name": "tech-digest",
  "version": "0.1.0",
  "type": "module",
  "description": "Local-first technology news digest dashboard.",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently -n api,web -c blue,green \"cross-env NODE_ENV=development APP_PORT=3001 tsx watch src/server/index.ts\" \"vite --host 127.0.0.1 --port 3000\"",
    "build": "vite build && tsc -p tsconfig.server.json",
    "start": "cross-env NODE_ENV=production node dist/server/server/index.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.server.json --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/static": "^8.0.4",
    "better-sqlite3": "^11.7.0",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.1",
    "lucide-react": "^0.468.0",
    "node-cron": "^3.0.3",
    "node-html-parser": "^6.1.13",
    "openai": "^6.35.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "rss-parser": "^3.13.0",
    "yaml": "^2.6.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.5",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "jsdom": "^25.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.6",
    "vitest": "^2.1.8"
  }
}
