NODE_ENV=production
APP_HOST=127.0.0.1
APP_PORT=3000
TIMEZONE=Asia/Shanghai
DIGEST_CRON=30 8 * * *
DIGEST_TOP_N=12
DATABASE_PATH=data/tech-digest.sqlite
SOURCES_FILE=sources.yaml

# Provider options:
# - openai: official OpenAI Responses API
# - openai-compatible: DeepSeek, SiliconFlow, OpenRouter, Moonshot, DashScope compatible endpoints, etc.
# - heuristic: local rule-based fallback with no API key
LLM_PROVIDER=openai
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
RUN_ON_START=false
